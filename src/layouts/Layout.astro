---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Epipelagic Ventures | Startup Accelerator & Investment Platform",
  description = "Epipelagic Ventures helps ambitious startup founders reach new business milestones with long-term support, investment, mentorship, and workspace in Kendall Square, Cambridge.",
} = Astro.props;

const siteUrl = "https://www.epipelagic.vc";
const ogImage = `${siteUrl}/epip1.jpg`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <link rel="canonical" href={siteUrl} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#f0ebe4" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Epipelagic" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Epipelagic Ventures" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Epipelagic Ventures",
      "url": siteUrl,
      "logo": `${siteUrl}/favicon.svg`,
      "description": description,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "1 Broadway, Suite 15-100",
        "addressLocality": "Cambridge",
        "addressRegion": "MA",
        "postalCode": "02142",
        "addressCountry": "US"
      },
      "email": "info@epipelagic.vc",
      "sameAs": [
        "https://www.linkedin.com/company/epipelagic-ventures/"
      ]
    })} />

    <!-- Preconnects -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" />

    <!-- Fonts — only load weights actually used, with display=swap -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@500&family=IBM+Plex+Serif:wght@400&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@500&family=IBM+Plex+Serif:wght@400&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Preload hero image for LCP -->
    <link rel="preload" as="image" href="/11.jpg" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-surface text-text-primary antialiased selection:bg-primary selection:text-surface">
    <!-- Skip to main content link for accessibility -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-primary focus:text-text-inverse focus:px-4 focus:py-2 focus:rounded-xl focus:font-sans focus:text-sm"
    >
      Skip to main content
    </a>

    <slot />

    <script>
      import { initScrollAnimations, initSmoothScroll } from "@/lib/animations";

      document.addEventListener("DOMContentLoaded", () => {
        // Respect reduced motion preference
        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        if (!prefersReducedMotion) {
          initSmoothScroll();
          initScrollAnimations();
        } else {
          // Make all animated elements visible immediately
          document.querySelectorAll("[data-animate], [data-stagger]").forEach((el) => {
            (el as HTMLElement).style.opacity = "1";
            (el as HTMLElement).style.transform = "none";
          });
          document.querySelectorAll("[data-stagger]").forEach((container) => {
            Array.from(container.children).forEach((child) => {
              (child as HTMLElement).style.opacity = "1";
              (child as HTMLElement).style.transform = "none";
            });
          });
        }
      });
    </script>
  </body>
</html>
