---
const services = [
  {
    title: "Funding",
    description: "Partner with an investment team that can fuel your growth.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    image: "https://images.unsplash.com/photo-1553877522-43269d4ea984?w=600&q=80&auto=format&fit=crop",
  },
  {
    title: "Resources",
    description: "Tap into tools and resources that keep you progressing.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>`,
    image: "https://images.unsplash.com/photo-1497366216548-37526070297c?w=600&q=80&auto=format&fit=crop",
  },
  {
    title: "Mentorship",
    description: "Run your ideas by experienced mentors or practice your next pitch.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
    image: "https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&q=80&auto=format&fit=crop",
  },
  {
    title: "Networking",
    description: "Build relationships with teams and founders of all levels.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>`,
    image: "https://images.unsplash.com/photo-1515187029135-18ee286d815b?w=600&q=80&auto=format&fit=crop",
  },
  {
    title: "Education",
    description: "Fill in knowledge gaps on everything from business strategy to branding.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>`,
    image: "https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=600&q=80&auto=format&fit=crop",
  },
  {
    title: "Workspace",
    description: "Access amenities like Wifi, printers, conference rooms, and a kitchen.",
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`,
    image: "https://images.unsplash.com/photo-1497366811353-6870744d04b2?w=600&q=80&auto=format&fit=crop",
  },
];
---

<section id="features" class="relative py-24 px-4 sm:px-6 lg:px-8" aria-label="Our Services">
  <div class="max-w-7xl mx-auto">
    <!-- Section heading — split layout -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14" data-animate="up">
      <div class="max-w-xl">
        <span class="font-mono text-[10px] font-medium leading-[1.33] tracking-[0.12em] uppercase text-text-muted mb-4 block">
          Our Services
        </span>
        <h2 class="font-display text-[28px] sm:text-[36px] md:text-[48px] font-normal leading-[1] tracking-[-0.02em] text-text-primary">
          Hit the ground running with support from every angle.
        </h2>
      </div>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 font-mono text-[12px] font-medium tracking-[0.05em] uppercase text-text-primary hover:text-accent transition-colors shrink-0"
      >
        Get started
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <!-- All 6 cards in one grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5" data-stagger="0.08">
      {services.map((service) => (
        <div class="group relative rounded-2xl overflow-hidden bg-surface-card/60 border border-border hover:border-accent/30 transition-all duration-500 hover:-translate-y-1">
          <div class="relative aspect-[16/10] overflow-hidden">
            <img
              src={service.image}
              alt={service.title}
              width="600"
              height="375"
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-surface-card to-transparent opacity-60"></div>
          </div>
          <div class="p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-xl bg-surface border border-border flex items-center justify-center text-text-secondary group-hover:text-accent group-hover:border-accent/30 transition-colors duration-300">
                <Fragment set:html={service.icon} />
              </div>
              <h3 class="font-display text-[20px] font-normal leading-[1.2] tracking-[-0.01em] text-text-primary" aria-label={service.title}>
                {service.title}
              </h3>
            </div>
            <p class="font-sans text-[14px] leading-[1.6] text-text-secondary">
              {service.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
