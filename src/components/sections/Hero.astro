---
---

<section class="relative px-4 sm:px-6 lg:px-8 pt-[88px] pb-4" aria-label="Hero">
  <!-- Hero rounded container -->
  <div class="relative w-full rounded-[24px] overflow-hidden bg-surface-dark h-[86vh]">

    <!-- Background image — fetchpriority high for LCP -->
    <div class="absolute inset-0">
      <img
        src="/11.jpg"
        alt=""
        role="presentation"
        width="1400"
        height="900"
        class="w-full h-full object-cover scale-x-100"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </div>

    <!-- Content overlay -->
    <div class="relative z-10 flex flex-col justify-between h-full p-6 sm:p-8 lg:p-10">

      <!-- Top spacer -->
      <div></div>

      <!-- Bottom content area -->
      <div class="flex flex-col gap-6">

        <!-- Main heading + description + CTA -->
        <div class="max-w-lg relative">
          <h1
            class="relative z-10 font-display text-[36px] sm:text-[48px] md:text-[56px] lg:text-[68px] font-normal leading-[1] tracking-[-0.03em] text-text-inverse mb-5"
            data-animate="up"
            data-delay="0.1"
          >
            Investing in the future of technology
          </h1>

          <p
            class="relative z-10 max-w-sm font-sans text-[14px] sm:text-[16px] font-normal leading-[1.5] text-white/70 mb-6"
            data-animate="up"
            data-delay="0.2"
          >
            Reach the next stage of funding with long-term support and investment.
          </p>

          <a
            href="#contact"
            class="relative z-10 inline-flex items-center gap-2 bg-accent hover:bg-accent-hover text-primary font-sans text-[13px] font-medium leading-[1] px-5 py-3 rounded-xl transition-colors duration-200"
            data-animate="up"
            data-delay="0.3"
          >
            Join now
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Bottom row: badge left + video card right -->
        <div class="flex items-end justify-between gap-4">
          <div
            class="flex items-center gap-2 bg-primary/50 backdrop-blur-sm rounded-full px-3.5 py-1.5"
            data-animate="up"
            data-delay="0.5"
          >
            <span class="text-[14px]" aria-hidden="true">⭐</span>
            <span class="font-mono text-[10px] font-medium leading-[1.33] tracking-[0.12em] uppercase text-white/80">
              Rated best consultancy of 2026
            </span>
          </div>

          <!-- Video card bottom-right -->
          <div
            class="hidden sm:block relative"
            data-animate="left"
            data-delay="0.4"
          >
            <div class="bg-white/10 backdrop-blur-md rounded-2xl p-2.5 pb-3">
              <div class="relative w-[180px] lg:w-[210px] aspect-[16/10] rounded-xl overflow-hidden">
                <video
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="metadata"
                  class="w-full h-full object-cover"
                  aria-label="Epipelagic Ventures showreel"
                >
                  <source src="/epip.mp4" type="video/mp4" />
                </video>
              </div>
              <div class="flex items-center justify-between mt-2.5 px-1">
                <span class="font-mono text-[10px] font-medium leading-[1.33] tracking-[0.12em] uppercase text-white/60">
                  Watch Video
                </span>
                <span class="font-mono text-[10px] font-medium leading-[1.33] tracking-[0.12em] uppercase text-white/60">
                  3 Minutes
                </span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
