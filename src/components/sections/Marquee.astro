---
const items = [
  "Funding",
  "Mentorship",
  "Resources",
  "Networking",
  "Education",
  "Workspace",
  "Long-term Support",
  "Kendall Square",
  "12–18+ Months",
  "Startup Ecosystem",
];
---

<section class="relative py-8 my-8 overflow-hidden" aria-label="Our key offerings">
  <div class="marquee-container flex">
    <!-- First set -->
    <div class="marquee-track flex shrink-0 items-center">
      {items.map((item) => (
        <>
          <span class="w-2 h-2 rounded-full bg-accent shrink-0 mx-6 sm:mx-8"></span>
          <span class="font-display text-[20px] sm:text-[24px] font-normal tracking-[-0.01em] text-text-primary whitespace-nowrap shrink-0">
            {item}
          </span>
        </>
      ))}
    </div>
    <!-- Duplicate for seamless loop -->
    <div class="marquee-track flex shrink-0 items-center" aria-hidden="true">
      {items.map((item) => (
        <>
          <span class="w-2 h-2 rounded-full bg-accent shrink-0 mx-6 sm:mx-8"></span>
          <span class="font-display text-[20px] sm:text-[24px] font-normal tracking-[-0.01em] text-text-primary whitespace-nowrap shrink-0">
            {item}
          </span>
        </>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-container {
    width: max-content;
    animation: marquee 30s linear infinite;
  }
  .marquee-container:hover {
    animation-play-state: paused;
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-container {
      animation: none;
    }
  }
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
