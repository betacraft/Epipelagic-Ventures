---
---

<section id="contact" class="relative py-24 px-4 sm:px-6 lg:px-8" aria-label="Contact">
  <div class="max-w-7xl mx-auto">

    <!-- Heading area -->
    <div class="grid md:grid-cols-2 gap-6 mb-14" data-animate="up">
      <div>
        <span class="font-mono text-[10px] font-medium leading-[1.33] tracking-[0.12em] uppercase text-text-muted mb-4 block">
          Contact
        </span>
        <h2 class="font-display text-[28px] sm:text-[36px] md:text-[48px] font-normal leading-[1] tracking-[-0.02em] text-text-primary">
          Let's connect
        </h2>
      </div>
      <div class="flex items-end justify-end">
        <p class="font-sans text-[16px] font-normal leading-[1.6] text-text-secondary max-w-lg text-right">
          We're always looking for exceptional founders. Whether you're at the napkin stage or scaling fast, we'd love to hear your story.
        </p>
      </div>
    </div>

    <!-- Three contact cards — Email (dark), LinkedIn (light), Location (light) -->
    <div class="grid sm:grid-cols-3 gap-4 mb-6" data-stagger="0.1">

      <!-- Card 1: Email — DARK (primary color) -->
      <a
        href="#contact"
        class="contact-card group relative flex flex-col justify-between rounded-2xl bg-surface-dark border border-surface-dark p-6 sm:p-7 min-h-[280px] sm:min-h-[320px] overflow-hidden transition-all duration-300 hover:-translate-y-1"
      >
        <!-- Top row: icon + label -->
        <div class="flex items-start justify-between">
          <div class="w-11 h-11 rounded-xl bg-white/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-text-inverse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <span class="font-mono text-[10px] font-medium tracking-[0.12em] uppercase text-text-inverse/50">
            Email
          </span>
        </div>

        <!-- Bottom: contact value + hover arrow -->
        <div class="flex items-end justify-between">
          <span class="font-display text-[20px] sm:text-[24px] font-normal leading-[1.1] tracking-[-0.01em] text-text-inverse">
            info@epipelagic.vc
          </span>
          <svg class="w-5 h-5 text-text-inverse/40 group-hover:text-text-inverse group-hover:translate-x-1 group-hover:-translate-y-1 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
          </svg>
        </div>
      </a>

      <!-- Card 2: LinkedIn — LIGHT (surface-card) -->
      <a
        href="https://www.linkedin.com/company/epipelagic-ventures/"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card group relative flex flex-col justify-between rounded-2xl bg-surface-card border border-border p-6 sm:p-7 min-h-[280px] sm:min-h-[320px] overflow-hidden transition-all duration-300 hover:-translate-y-1"
      >
        <!-- Top row: icon + label -->
        <div class="flex items-start justify-between">
          <div class="w-11 h-11 rounded-xl bg-surface flex items-center justify-center border border-border">
            <svg class="w-5 h-5 text-text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
          </div>
          <span class="font-mono text-[10px] font-medium tracking-[0.12em] uppercase text-text-muted">
            LinkedIn
          </span>
        </div>

        <!-- Bottom: contact value + hover arrow -->
        <div class="flex items-end justify-between">
          <span class="font-display text-[20px] sm:text-[24px] font-normal leading-[1.1] tracking-[-0.01em] text-text-primary">
            Epipelagic Ventures
          </span>
          <svg class="w-5 h-5 text-text-muted group-hover:text-text-primary group-hover:translate-x-1 group-hover:-translate-y-1 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
          </svg>
        </div>
      </a>

      <!-- Card 3: Location — LIGHT (surface-card) -->
      <div
        class="contact-card group relative flex flex-col justify-between rounded-2xl bg-surface-card border border-border p-6 sm:p-7 min-h-[280px] sm:min-h-[320px] overflow-hidden transition-all duration-300 hover:-translate-y-1"
      >
        <!-- Top row: icon + label -->
        <div class="flex items-start justify-between">
          <div class="w-11 h-11 rounded-xl bg-surface flex items-center justify-center border border-border">
            <svg class="w-5 h-5 text-text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
            </svg>
          </div>
          <span class="font-mono text-[10px] font-medium tracking-[0.12em] uppercase text-text-muted">
            Location
          </span>
        </div>

        <!-- Bottom: address -->
        <div>
          <span class="font-display text-[20px] sm:text-[24px] font-normal leading-[1.2] tracking-[-0.01em] text-text-primary block">
            1 Broadway, Suite 15-100
          </span>
          <span class="font-sans text-[14px] text-text-secondary mt-1 block">
            Cambridge, MA 02142
          </span>
        </div>
      </div>
    </div>

    <!-- Disclaimer -->
    <p class="font-sans text-[13px] leading-[1.6] text-text-secondary max-w-none mb-16">
      While every effort is made to provide thoughtful and timely replies, not all submissions may result in a follow-up conversation. This space exists to initiate clarity, not to apply pressure or create expectations beyond an initial exchange.
    </p>

    <!-- Newsletter section below -->
    <div class="w-full h-px bg-border mt-16 mb-16"></div>
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-start">
      <div data-animate="up">
        <span class="font-mono text-[10px] font-medium leading-[1.33] tracking-[0.12em] uppercase text-text-muted mb-4 block">
          Newsletter
        </span>
        <h3 class="font-display text-[28px] sm:text-[36px] font-normal leading-[1.1] tracking-[-0.02em] text-text-primary mb-3">
          Stay up to date on the latest updates.
        </h3>
        <p class="font-sans text-[14px] leading-[1.5] text-text-secondary">
          Get news about our portfolio, events, and startup ecosystem insights delivered to your inbox.
        </p>
      </div>

      <div class="flex items-end" data-animate="up" data-delay="0.1">
        <form class="w-full flex flex-col sm:flex-row gap-3" onsubmit="return false;">
          <label for="newsletter-email" class="sr-only">Email address</label>
          <input
            id="newsletter-email"
            type="email"
            placeholder="Your email address"
            class="flex-1 bg-surface-card border border-border rounded-xl px-4 py-3.5 font-sans text-[14px] text-text-primary placeholder:text-text-muted focus:outline-none focus:border-accent transition-colors"
          />
          <button
            type="submit"
            class="bg-primary text-text-inverse font-sans text-[13px] font-medium px-6 py-3.5 rounded-xl hover:bg-primary-light transition-colors whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>
    <div class="w-full h-px bg-border mt-16"></div>
  </div>
</section>
