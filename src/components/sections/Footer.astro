---
const currentYear = new Date().getFullYear();

const links = {
  pages: [
    { label: "Studio", href: "#about" },
    { label: "Venture", href: "#features" },
    { label: "About", href: "#about" },
    { label: "Opportunities", href: "#contact" },
    { label: "Contact", href: "#contact" },
  ],
  legal: [
    { label: "Privacy Policy", href: "#" },
    { label: "Disclaimer", href: "#" },
  ],
  social: [
    { label: "LinkedIn", href: "https://www.linkedin.com/company/epipelagic-ventures/" },
  ],
};
---

<footer class="relative px-4 sm:px-6 lg:px-8 pt-8 pb-8" aria-label="Site footer">
  <div class="max-w-7xl mx-auto">

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-16">
      <!-- Brand + Address -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <svg class="w-5 h-5 text-text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="3" width="7" height="7" rx="1" />
            <rect x="14" y="3" width="7" height="7" rx="1" />
            <rect x="3" y="14" width="7" height="7" rx="1" />
            <rect x="14" y="14" width="7" height="7" rx="1" />
          </svg>
          <span class="font-display text-[18px] font-medium tracking-[-0.02em] text-text-primary">
            Epipelagic<span class="text-text-muted align-super text-[10px] ml-0.5">™</span>
          </span>
        </a>
        <p class="font-sans text-[14px] leading-[1.6] text-text-secondary mb-4">
          1 Broadway, Suite 15-100<br/>
          Cambridge, MA 02142
        </p>
        <a href="mailto:info@epipelagic.vc" class="font-sans text-[14px] text-text-secondary hover:text-text-primary transition-colors">
          info@epipelagic.vc
        </a>
      </div>

      <!-- Pages links -->
      <div>
        <h4 class="font-mono text-[10px] font-medium tracking-[0.12em] uppercase text-text-muted mb-5">Pages</h4>
        <ul class="space-y-3">
          {links.pages.map((link) => (
            <li>
              <a href={link.href} class="font-sans text-[14px] text-text-secondary hover:text-text-primary transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal links -->
      <div>
        <h4 class="font-mono text-[10px] font-medium tracking-[0.12em] uppercase text-text-muted mb-5">Legal</h4>
        <ul class="space-y-3">
          {links.legal.map((link) => (
            <li>
              <a href={link.href} class="font-sans text-[14px] text-text-secondary hover:text-text-primary transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social links -->
      <div>
        <h4 class="font-mono text-[10px] font-medium tracking-[0.12em] uppercase text-text-muted mb-5">Social</h4>
        <ul class="space-y-3">
          {links.social.map((link) => (
            <li>
              <a href={link.href} target="_blank" rel="noopener" class="font-sans text-[14px] text-text-secondary hover:text-text-primary transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-mono text-[10px] font-medium tracking-[0.05em] uppercase text-text-muted">
        &copy; {currentYear} Epipelagic Ventures. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a href="#" class="font-mono text-[10px] font-medium tracking-[0.05em] uppercase text-text-muted hover:text-text-primary transition-colors">Privacy Policy</a>
        <a href="#" class="font-mono text-[10px] font-medium tracking-[0.05em] uppercase text-text-muted hover:text-text-primary transition-colors">Disclaimer</a>
      </div>
    </div>
  </div>
</footer>
