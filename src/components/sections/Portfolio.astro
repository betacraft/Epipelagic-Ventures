---
---

<!-- "Be part of our growing ecosystem" CTA banner -->
<section id="portfolio" class="relative py-16 px-4 sm:px-6 lg:px-8" aria-label="Join our ecosystem">
  <div class="max-w-7xl mx-auto">
    <div class="relative rounded-[24px] overflow-hidden bg-surface-dark py-20 px-8 sm:px-14 lg:px-20">
      <!-- Subtle texture -->
      <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>

      <div class="relative z-10 max-w-2xl mx-auto text-center" data-animate="up">
        <span class="font-mono text-[10px] font-medium leading-[1.33] tracking-[0.12em] uppercase text-text-muted mb-4 block">
          Join Us
        </span>
        <h2 class="font-display text-[28px] sm:text-[36px] md:text-[48px] font-normal leading-[1] tracking-[-0.02em] text-text-inverse mb-6">
          Be part of our growing ecosystem.
        </h2>
        <a
          href="#contact"
          class="inline-flex items-center gap-2 bg-accent hover:bg-accent-hover text-primary font-sans text-[13px] font-medium leading-[1] px-6 py-3.5 rounded-xl transition-colors duration-200"
        >
          Apply today
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
